{
  "name": "Ambiente de Desenvolvimento",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "api",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": false,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers-extra/features/mise:1": {
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true
      },
      "extensions": [
        "prisma.prisma",
        "mikestead.dotenv",
        "usernamehw.errorlens",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian",
        "jeff-hykin.better-dockerfile-syntax",
        "pkief.material-icon-theme",
        "eamodio.gitlens",
        "mylesmurphy.prettify-ts",
        "yoavbls.pretty-ts-errors",
        "inferrinizzard.prettier-sql-vscode",
        "biomejs.biome",
        "hverlin.mise-vscode"
      ]
    }
  },

  "containerEnv": {
    "NODE_ENV": "development",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "GITHUB_USERNAME": "${localEnv:MY_GIT_USER}",
    "GITHUB_EMAIL": "${localEnv:MY_GIT_EMAIL}"
  },

  "mounts": [
    "source=${localEnv:HOME}/.ssh/${localEnv:MY_SSH_KEY_NAME}.pub,target=/home/vscode/.ssh/signing_key.pub,type=bind,readonly"
  ],

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "remoteUser": "vscode"
}
