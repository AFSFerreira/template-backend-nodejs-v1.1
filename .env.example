# Infra:
NODE_ENV=development
LOG_LEVEL=debug
PROJECT_NAME=TemplateBackend

# App:
APP_NAME=TemplateBackend
APP_PORT=3000

# JWT Token:
JWT_SECRET=
JWT_EXPIRATION=2h
JWT_REFRESH_EXPIRATION=7d
# Base64 32 bytes sized token:
ENCRYPTION_KEY=
# Base64 32 bytes sized token:
BLIND_INDEX_SECRET=

# Configuração Argon2:
ARGON_MEMORY_COST=
ARGON_TIME_COST=

# Sentry:
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_URL=
SENTRY_ORG=
SENTRY_PROJECT=

# Memória:
MAX_RAM_MB=

# Comando de inicialização do Dockerfile:
COMMAND="npx prisma migrate deploy && npx prisma generate && node dist/seed.js && npm run start:prod:docker"

# Comando de paralelização do Docker Compose file:
COMPOSE_BAKE=true
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
COMPOSE_PARALLEL_BUILD=1

# PostgreSQL:
POSTGRES_CONTAINER_NAME=template-pg
POSTGRES_HOST=127.0.0.1
POSTGRES_USERNAME=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=templatebackend
POSTGRES_PORT=5432
SCHEMA=public
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000

# REDIS:
REDIS_CONTAINER_NAME=template-redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# URLs de Conexão:
DATABASE_URL=postgresql://postgres-user:postgres-password@postgres:5432/templatebackend?schema=public
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# Rate Limiting (por minuto):
RATE_LIMIT_STANDARD_MAX=300
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_MUTATION_MAX=30
RATE_LIMIT_HEAVY_MAX=10
RATE_LIMIT_CREATE_RESOURCE_MAX=15

# SMTP:
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_PORT=
SMTP_HOST=
SMTP_SECURE=

# Identidade do DevContainer:
# Coloque o nome do arquivo da sua chave pública (sem o .pub)
MY_SSH_KEY_NAME=id_ed25519
MY_GIT_USER=seu-username
MY_GIT_EMAIL=seu.email@dominio.com
GITHUB_TOKEN=seu-token-github
