{
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Gere mensagens de commit SEMPRE em Português do Brasil (PT-BR). Use ESTRITAMENTE apenas o tipo `chore` no padrão Conventional Commits (ex.: `chore: ajusta validacao de entrada`). Seja conciso."
    }
  ],
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "cSpell.words": ["bullmq", "envsubst", "tsgo", "tsyringe", "vegeta"]
}
