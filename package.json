{
  "name": "template-backend-nodejs-v1",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "license": "ISC",
  "packageManager": "bun@1.3.11",
  "author": "",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "start:dev": "bun --watch src/server.ts",
    "build": "bun run db:generate && bun run ./build.ts",
    "start:tsx:watch": "tsx watch --env-file=.env --no-deprecation src/server.ts",
    "start:prod": "node --enable-source-maps --env-file=.env dist/server.mjs",
    "start:prod:docker": "node --enable-source-maps dist/server.mjs",
    "build:tsc": "tsc",
    "build:tsgo": "tsgo",
    "build:tsdown": "tsdown --config ./tsdown.config.ts",
    "lint:src:biome": "biome lint --write src",
    "lint:prisma:biome": "biome lint --write prisma",
    "format:src:biome": "biome format --write src",
    "format:prisma:biome": "biome format --write prisma",
    "check:src:biome": "biome check --write src",
    "check:prisma:biome": "biome check --write prisma",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:reset": "bun run db:generate && bun run db:migrate:reset && bun run db:seed",
    "db:migrate-deploy": "prisma migrate deploy",
    "db:deploy": "bun run db:migrate-deploy && bun run db:generate && bun run db:seed",
    "ci:generate": "bun run db:generate",
    "ci:lint": "bun run check:prisma:biome & bun run check:src:biome & wait",
    "ci:format": "bun run check:prisma:biome & bun run check:src:biome & wait",
    "ci:build": "bun run ci:generate && bun run build:tsgo && bun run build:tsdown",
    "sentry:upload": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist",
    "test:load:local": "BASE_URL=http://localhost:3000 envsubst < ./load-tests/targets.local.txt | vegeta attack -duration=10s -rate=3 | vegeta report",
    "test:load:stg": "BASE_URL=https://api-staging.example.com envsubst < load-tests/targets.stg.txt | vegeta attack -duration=10s -rate=10 | vegeta report",
    "preinstall": "npx only-allow bun",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@sentry/cli": "3.3.4",
    "@swc/core": "1.15.26",
    "@types/fs-extra": "11.0.4",
    "@types/html-minifier-terser": "7.0.2",
    "@types/html-to-text": "9.0.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/ms": "2.1.0",
    "@types/multer": "2.1.0",
    "@types/nodemailer": "8.0.0",
    "@types/nunjucks": "3.2.6",
    "@types/sanitize-html": "2.16.1",
    "@types/ws": "8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "commitlint": "20.5.0",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "pino-pretty": "13.1.3",
    "prisma": "7.6.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@fastify/compress": "8.3.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/under-pressure": "9.0.3",
    "@fastify/websocket": "11.2.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@sentry/bun": "10.47.0",
    "@types/bun": "1.3.12",
    "bullmq": "5.74.1",
    "cron-validator": "1.4.0",
    "dayjs": "1.11.20",
    "fast-glob": "3.3.3",
    "fastify": "5.8.4",
    "fastify-type-provider-zod": "6.1.0",
    "fs-extra": "11.3.4",
    "html-minifier-terser": "7.2.0",
    "html-to-text": "9.0.5",
    "http-status-codes": "2.3.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "ms": "2.1.3",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.5",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "reflect-metadata": "0.2.2",
    "sanitize-html": "2.17.3",
    "tsyringe": "4.10.0",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  }
}
